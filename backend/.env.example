# Server
PORT=5000
NODE_ENV=development

# CORS - allowed origins (comma-separated). Each entry is matched exactly
# against the browser's Origin header. Include every frontend URL that
# should be able to call this API. Defaults to localhost:3000 +
# tool-1-9t7t.onrender.com when unset.
# Example:
# CORS_ORIGINS=http://localhost:3000,https://tool-oxax.onrender.com,https://tool-1-9t7t.onrender.com
CORS_ORIGINS=http://localhost:3000

# PostgreSQL - DART Database
# Option 1: DATABASE_URL (recommended for Render.com and cloud deployments)
# DATABASE_URL=postgresql://username:password@host:5432/database_name
# DATABASE_URL=postgresql://render_username:render_password@your-db-name.c.render.com:5432/your_db_name

# Option 2: Individual environment variables (for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dart_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT — required. The process refuses to boot if either secret is missing.
JWT_ACCESS_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AES-256-CBC key used to encrypt target-cluster passwords at rest in the
# connections table. Required — utils/encryption.ts throws at module load if
# this is missing. Treat as a long-lived secret: rotating it invalidates
# every saved cluster password.
ENCRYPTION_KEY=change-this-to-a-strong-random-string
