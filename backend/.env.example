# Server
PORT=5000
NODE_ENV=development

# PostgreSQL - DART Database
# Local development defaults:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dart_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# For Render.com deployment:
# Create a PostgreSQL database on Render and use its connection details
# DB_HOST=your-database-name.c.render.com
# DB_PORT=5432
# DB_NAME=your_database_name
# DB_USER=your_username
# DB_PASSWORD=your_password_from_render

# JWT
JWT_ACCESS_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
